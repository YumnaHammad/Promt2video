generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum VideoStatus {
  DRAFT
  GENERATING
  EDITING
  RENDERING
  COMPLETED
  FAILED
  ARCHIVED
}

enum RenderJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum AssetType {
  IMAGE
  VIDEO
  AUDIO
  MUSIC
  FONT
  LOGO
  LOTTIE
  SVG
}

enum AssetSource {
  PEXELS
  PIXABAY
  UNSPLASH
  UPLOAD
  AI_GENERATED
  STOCK
}

enum ApiProvider {
  OPENAI
  GEMINI
  ANTHROPIC
  OPENROUTER
  ELEVENLABS
  KLING
  RUNWAY
  VEO
}

enum NotificationType {
  RENDER_COMPLETE
  RENDER_FAILED
  SUBSCRIPTION
  PURCHASE
  SYSTEM
  COLLABORATION
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum CollaboratorRole {
  VIEWER
  EDITOR
  ADMIN
}

model User {
  id               String    @id @default(cuid())
  clerkId          String    @unique
  email            String    @unique
  name             String?
  avatarUrl        String?
  role             UserRole  @default(USER)
  onboardingDone   Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization     Organization? @relation(fields: [organizationId], references: [id])
  organizationId   String?

  subscription     Subscription?
  apiKeys          ApiKey[]
  projects         Project[]
  videos           Video[]
  purchases        Purchase[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  favorites        TemplateFavorite[]
  comments         Comment[]
  collaborations   Collaborator[]
  mediaLibrary     MediaLibrary[]
  brandKits        BrandKit[]
  settings         UserSettings?

  @@index([clerkId])
  @@index([email])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     User[]
  projects    Project[]
  brandKits   BrandKit[]

  @@index([slug])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([stripeCustomerId])
}

model ApiKey {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     ApiProvider
  encryptedKey String
  label        String?
  isValid      Boolean     @default(false)
  lastValidated DateTime?
  usageCount   Int         @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  description    String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  videos         Video[]

  @@index([userId])
}

model Video {
  id              String      @id @default(cuid())
  title           String
  description     String?
  prompt          String?
  status          VideoStatus @default(DRAFT)
  duration        Float       @default(0)
  fps             Int         @default(30)
  width           Int         @default(1920)
  height          Int         @default(1080)
  aspectRatio     String      @default("16:9")
  thumbnailUrl    String?
  outputUrl       String?
  remotionData    Json?
  scriptData      Json?
  storyData       Json?
  subtitleData    Json?
  brandKitId      String?
  brandKit        BrandKit?   @relation(fields: [brandKitId], references: [id])
  templateId      String?
  template        Template?   @relation(fields: [templateId], references: [id])
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project?    @relation(fields: [projectId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  scenes          Scene[]
  renderJobs      RenderJob[]
  comments        Comment[]
  collaborators   Collaborator[]

  @@index([userId])
  @@index([status])
}

model Scene {
  id            String   @id @default(cuid())
  videoId       String
  video         Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  order         Int
  title         String?
  narration     String?
  visualPrompt  String?
  duration      Float    @default(5)
  speed         Float    @default(1)
  volume        Float    @default(1)
  transition    String   @default("fade")
  captionStyle  Json?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assets        SceneAsset[]
  voice         Voice?

  @@index([videoId])
  @@index([videoId, order])
}

model SceneAsset {
  id        String    @id @default(cuid())
  sceneId   String
  scene     Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id])
  role      String    @default("background")
  startTime Float     @default(0)
  endTime   Float?
  opacity   Float     @default(1)
  scale     Float     @default(1)
  position  Json?

  @@index([sceneId])
}

model Asset {
  id          String      @id @default(cuid())
  name        String
  type        AssetType
  source      AssetSource
  url         String
  thumbnailUrl String?
  mimeType    String?
  fileSize    Int?
  width       Int?
  height      Int?
  duration    Float?
  metadata    Json?
  userId      String?
  createdAt   DateTime    @default(now())

  sceneAssets SceneAsset[]
  mediaLibrary MediaLibrary[]

  @@index([type])
  @@index([userId])
}

model Voice {
  id          String   @id @default(cuid())
  sceneId     String   @unique
  scene       Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  provider    String   @default("free-tts")
  voiceId     String?
  audioUrl    String?
  duration    Float?
  transcript  String?
  subtitles   Json?
  createdAt   DateTime @default(now())
}

model MusicTrack {
  id          String   @id @default(cuid())
  title       String
  artist      String?
  url         String
  duration    Float
  genre       String?
  mood        String?
  isPremium   Boolean  @default(false)
  source      AssetSource
  createdAt   DateTime @default(now())

  @@index([genre])
  @@index([mood])
}

model Template {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String
  category      String
  tags          Json             @default("[]")
  thumbnailUrl  String
  previewUrl    String?
  isPremium     Boolean  @default(false)
  price         Float    @default(0)
  stripePriceId String?
  remotionData  Json
  sceneCount    Int      @default(1)
  duration      Float    @default(30)
  aspectRatio   String   @default("16:9")
  downloads     Int      @default(0)
  rating        Float    @default(0)
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  videos        Video[]
  purchases     Purchase[]
  favorites     TemplateFavorite[]

  @@index([category])
  @@index([isPremium])
  @@index([slug])
}

model TemplateFavorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, templateId])
}

model Purchase {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId      String?
  template        Template?      @relation(fields: [templateId], references: [id])
  stripePaymentId String?        @unique
  stripeInvoiceId String?
  amount          Float
  currency        String         @default("usd")
  status          PurchaseStatus @default(PENDING)
  couponId        String?
  coupon          Coupon?        @relation(fields: [couponId], references: [id])
  receiptUrl      String?
  createdAt       DateTime       @default(now())

  @@index([userId])
  @@index([status])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("percent")
  discountValue Float
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  purchases     Purchase[]

  @@index([code])
}

model RenderJob {
  id           String          @id @default(cuid())
  videoId      String
  video        Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  status       RenderJobStatus @default(QUEUED)
  progress     Float           @default(0)
  type         String          @default("final")
  outputUrl    String?
  error        String?
  bullJobId    String?
  startedAt    DateTime?
  completedAt  DateTime?
  retryCount   Int             @default(0)
  metadata     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([videoId])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

model BrandKit {
  id             String   @id @default(cuid())
  name           String
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  primaryColor   String   @default("#6366f1")
  secondaryColor String   @default("#8b5cf6")
  accentColor    String   @default("#ec4899")
  fontFamily     String   @default("Inter")
  logoUrl        String?
  watermarkUrl   String?
  watermarkOpacity Float  @default(0.3)
  captionStyle   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  videos         Video[]

  @@index([userId])
}

model MediaLibrary {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id])
  folder    String   @default("default")
  createdAt DateTime @default(now())

  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  timestamp Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoId])
}

model Collaborator {
  id        String           @id @default(cuid())
  videoId   String
  video     Video            @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      CollaboratorRole @default(VIEWER)
  createdAt DateTime         @default(now())

  @@unique([videoId, userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model UserSettings {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme             String  @default("dark")
  language          String  @default("en")
  defaultFps        Int     @default(30)
  defaultResolution String  @default("1920x1080")
  emailNotifications Boolean @default(true)
  renderNotifications Boolean @default(true)
  keyboardShortcuts Json?
}

model SystemSettings {
  id    String @id @default(cuid())
  key   String @unique
  value Json
  updatedAt DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}
